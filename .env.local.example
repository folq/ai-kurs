# Vercel AI Gateway configuration
# Used by AI SDK gateway provider (chat + structured outputs + embeddings)
AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# Optional: self-hosted/custom AI Gateway base URL
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/ai

# Used by seed script to precompute vector embeddings in SQLite
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
